<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="load-account-status" author="acukitoro" runOnChange="true">
        <loadUpdateData tableName="account_status"
                        file="db/changelog/data/account_status.csv"
                        primaryKey="id"
                        encoding="UTF-8"
        />
    </changeSet>
</databaseChangeLog>